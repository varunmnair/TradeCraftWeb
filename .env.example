# =============================================================================
# Application Mode
# =============================================================================
# Primary switch: "dev" or "prod"
# - dev: Development mode (default) - shows detailed errors, allows dev shortcuts
# - prod: Production mode - strict CORS, sanitized errors, validates required config
# APP_MODE=dev

# Legacy environment variables (deprecated, use APP_MODE instead)
# DEV_MODE=1          # Deprecated: use APP_MODE=dev
# HOSTED_MODE=0      # Deprecated: use APP_MODE=prod

# =============================================================================
# Database Configuration
# =============================================================================
# The DATABASE_URL is determined in this priority order:
# 1. This DATABASE_URL environment variable (if set)
# 2. Default: sqlite:///./data/tradecraftx.db
#
# Development (default):
#   DATABASE_URL=sqlite:///./data/tradecraftx.db
#
# Production (examples):
#   PostgreSQL: postgresql://user:pass@host:5432/tradecraftx
#   MySQL: mysql://user:pass@host:3306/tradecraftx
#   SQLite (different path): sqlite:///var/data/tradecraftx.db
#
# To use the default, leave DATABASE_URL unset or comment it out
# DATABASE_URL=sqlite:///./data/tradecraftx.db

# =============================================================================
# Broker Credentials
# =============================================================================
KITE_API_KEY=your_zerodha_api_key
KITE_API_SECRET=your_zerodha_api_secret
KITE_REDIRECT_URI=http://localhost:8000/brokers/zerodha/callback

UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/brokers/upstox/callback

# Long-lived Analytics token (read-only) for CMP/OHLCV data
# Create an "Analytics" app in Upstox developer portal and generate token
UPSTOX_ANALYTICS_TOKEN=your_analytics_long_lived_token_here

# =============================================================================
# Application Security (Required in prod)
# =============================================================================
# JWT_SECRET=<generate-a-secure-random-string>
# TOKEN_ENCRYPTION_KEY=<base64url-32-byte-key>

# Optional in dev, required in prod
# ALLOW_INSECURE_TOKENS=1  # Set to 0 in prod (default: 1 in dev)

# =============================================================================
# Admin User (Set after registering first user)
# =============================================================================
# After registering via POST /auth/register, set this to promote that user to admin
# BOOTSTRAP_ADMIN_EMAIL=admin@tradecraftx.com

# =============================================================================
# AI Provider Credentials (Optional)
# =============================================================================
# GEMINI_API_KEY=your_google_gemini_api_key
# GROQ_API_KEY=your_groq_api_key
