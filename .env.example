# =============================================================================
# Application Mode
# =============================================================================
# Primary switch: "dev" or "prod"
# - dev: Development mode (default) - shows detailed errors, allows dev shortcuts
# - prod: Production mode - strict CORS, sanitized errors, validates required config
# APP_MODE=dev

# Legacy environment variables (deprecated, use APP_MODE instead)
# DEV_MODE=1          # Deprecated: use APP_MODE=dev
# HOSTED_MODE=0      # Deprecated: use APP_MODE=prod

# =============================================================================
# Database
# =============================================================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/tradecraftx

# =============================================================================
# Broker Credentials
# =============================================================================
KITE_API_KEY=your_zerodha_api_key
KITE_API_SECRET=your_zerodha_api_secret
KITE_REDIRECT_URI=http://localhost:8000/brokers/zerodha/callback

UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/brokers/upstox/callback

# =============================================================================
# Application Security (Required in prod)
# =============================================================================
# JWT_SECRET=<generate-a-secure-random-string>
# TOKEN_ENCRYPTION_KEY=<base64url-32-byte-key>

# Optional in dev, required in prod
# ALLOW_INSECURE_TOKENS=1  # Set to 0 in prod (default: 1 in dev)

# =============================================================================
# AI Provider Credentials (Optional)
# =============================================================================
# GEMINI_API_KEY=your_google_gemini_api_key
# GROQ_API_KEY=your_groq_api_key
